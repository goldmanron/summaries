\begin_layout Definition
\begin_inset Argument 1
status open

\begin_layout Plain Layout
Block Cipher
\end_layout

\end_inset

 A 
\series bold
block cipher 
\series default
is a implementation of a keyed pseudorandom permutation,
 with 
\begin_inset Formula $\KK=\str n$
\end_inset

.
\end_layout

\begin_layout Remark
To encrypt messages longer than 
\begin_inset Formula $n$
\end_inset

,
 you divide the message to 
\begin_inset Formula $n$
\end_inset

-bit blocks (maybe expand the last),
 and then encrypt as
\begin_inset Formula 
\[
\enc_{k}\left(m\right)=\left(\left(r_{1},F_{k}\left(r_{1}\oplus m_{1}\right)\right),\ldots,\left(r_{t},F_{k}\left(r_{t}\oplus m_{t}\right)\right)\right)
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Remark
A block cipher is 
\series bold
not 
\series default
an encryption scheme,
 modes of operations are 
\begin_inset Quotes qld
\end_inset

wrappers
\begin_inset Quotes qrd
\end_inset

 that turns a block cipher into a full-fledged encryption scheme.
\end_layout

