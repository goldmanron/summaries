\begin_layout Proof
If 
\begin_inset Formula $b=0$
\end_inset

,
 
\begin_inset Formula $\Pr\left[b'=0\right]=\Pr\left[\mathcal{A}_{\enc}\text{ wins}\right]=0.5+\delta$
\end_inset

.
\end_layout

\begin_layout Proof
If 
\begin_inset Formula $b=1$
\end_inset

,
 
\begin_inset Formula $\Pr\left[b'=0\right]=\Pr\left[\mathcal{A}_{\enc}\text{ wins against random function}\right]=0.5+t2^{-n}$
\end_inset

.
\end_layout

\begin_layout Proof
All in all,
 
\begin_inset Formula $\Pr\left[b'=b\right]\geq0.5+0.5\left(\delta-t2^{-n}\right)$
\end_inset

,
 and thus for 
\begin_inset Formula $\delta=2\varepsilon+t/2^{n}$
\end_inset

 we get a contradiction,
 since the complexity of 
\begin_inset Formula $\mathcal{A}_{\prf}$
\end_inset

 is that of 
\begin_inset Formula $\mathcal{A}_{\enc}$
\end_inset

 times 
\begin_inset Formula $n$
\end_inset

 because XORing a string takes 
\begin_inset Formula $O\left(n\right)$
\end_inset

.
\end_layout

