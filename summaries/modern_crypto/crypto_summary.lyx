\begin_layout Enumerate
MixCol:
 maps the state to a new one.
\begin_inset Newline newline
\end_inset

It multiplies each column of state by the polynomial 
\begin_inset Formula $c\left(x\right)\mod{\left(x^{4}+1\right)}$
\end_inset

,
 where
\begin_inset Formula 
\[
c\left(x\right)=\texttt{0x03}x^{3}+\texttt{0x01}x^{2}+\texttt{0x01}x+\texttt{0x02}.
\]

\end_inset

Specifically,
 for the first column,
\begin_inset Formula 
\[
S_{0,0}'x^{3}+S_{1,0}'x^{2}+S_{2,0}'x+S_{3,0}'=\left(\texttt{0x03}x^{3}+\texttt{0x01}x^{2}+\texttt{0x01}x+\texttt{0x02}\right)\cdot\left(S_{0,0}x^{3}+S_{1,0}x^{2}+S_{2,0}x+S_{3,0}\right)\mod{\left(x^{4}+1\right).}
\]

\end_inset

The inverse operation is InvMixCol:
 It multiplies each column of state by the polynomial 
\begin_inset Formula $d\left(x\right)\mod{\left(x^{4}+1\right)}$
\end_inset

,
 where
\begin_inset Formula 
\[
d\left(x\right)=\texttt{0x0b}x^{3}+\texttt{0x0d}x^{2}+\texttt{0x09}x+\texttt{0x0e}.
\]

\end_inset


\end_layout

\begin_deeper
\begin_layout Remark
All these coefficients from 
\begin_inset Formula $c(x)$
\end_inset

 and 
\begin_inset Formula $d(x)$
\end_inset

 (
\begin_inset Formula $\texttt{0x03,0x01,0x02,0x0b,0x0d,0x09,0x0e}$
\end_inset

) are hexadecimal constants from 
\begin_inset Formula $GF\left(2^{8}\right)$
\end_inset

 (which are low degree polynomials,
 e.g.
 
\begin_inset Formula $\texttt{0x0e}$
\end_inset

 in hex is 14 in decimal,
 1110 in binary,
 and 
\begin_inset Formula $x^{3}+x^{2}+x$
\end_inset

 as a polynomial).
\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Remark
These 
\begin_inset Formula $c(x)$
\end_inset

 and 
\begin_inset Formula $d(x)$
\end_inset

 correspond to the first (left most) column.
 The other columns have different but similar coefficients/polynomials.
\end_layout

