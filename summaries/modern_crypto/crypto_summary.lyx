-th Feistel round on an input 
\begin_inset Formula $\left(L_{0},R_{0}\right)\in\str{2n}$
\end_inset

 for a function collection 
\begin_inset Formula $f:\KK\times\str n\xrightarrow{}\str n$
\end_inset

:
\end_layout

\begin_deeper
\begin_layout Enumerate

\series bold
Recursion:
 
\series default
Compute 
\begin_inset Formula $\left(L_{i-1},R_{i-1}\right)\in\str{2n}$
\end_inset


\end_layout

\begin_layout Enumerate

\series bold
Function Application:
 
\series default
Compute 
\begin_inset Formula $f\left(k_{i},R_{i-1}\right)$
\end_inset

 using the 
\begin_inset Formula $i$
\end_inset

-th part of the key 
\begin_inset Formula $k_{i}$
\end_inset


\end_layout

\begin_layout Enumerate

\series bold
XOR & Swap:
 
\series default

\begin_inset Formula $L_{i}\xleftarrow{}R_{i-1},R_{i}\xleftarrow{}L_{i-1}\oplus f\left(k_{i},R_{i-1}\right)$
\end_inset


\end_layout

\begin_layout Enumerate
Return 
\begin_inset Formula $F_{i}\left(L_{0},R_{0}\right)=\left(L_{i},R_{i}\right)$
\end_inset


\end_layout

\end_deeper
