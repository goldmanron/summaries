\begin_layout Section
Perfect Secrecy
\end_layout

\begin_layout Definition
Two distributions 
\begin_inset Formula $X,Y$
\end_inset

 over 
\begin_inset Formula $\mathcal{D}$
\end_inset

 are 
\series bold
equal
\series default
,
 denoted by 
\begin_inset Formula $X\equiv Y$
\end_inset

,
 if 
\begin_inset Formula $\forall d\in\mathcal{D}.\ \Pr\left[X=d\right]=\Pr\left[Y=d\right]$
\end_inset

.
\end_layout

\begin_layout Definition
\begin_inset Argument 1
status open

\begin_layout Plain Layout
Perfect Secrecy (Shannon 1949)
\end_layout

\end_inset

 We say 
\begin_inset Formula $\left(\enc,\dec\right)$
\end_inset

 is 
\series bold
perfectly secret 
\series default
if for any a priori distribution 
\begin_inset Formula $M$
\end_inset

 of messages,
 and 
\begin_inset Formula $k\r\KK$
\end_inset

,
 
\begin_inset Formula $M|\enc_{k}\left(M\right)\equiv M$
\end_inset

.
\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Definition
\begin_inset Argument 1
status open

\begin_layout Plain Layout
Perfect Indistinguishability
\end_layout

\end_inset

We say 
\begin_inset Formula $\left(\enc,\dec\right)$
\end_inset

 is 
\series bold
perfectly
\series default
 
\series bold
indistinguishable
\series default
 if for any 
\begin_inset Formula $m_{0},m_{1}\in\mathcal{M}$
\end_inset

 of equal length,
 if 
\begin_inset Formula $k\r\KK$
\end_inset

,
 then 
\begin_inset Formula $\enc_{k}\left(m_{0}\right)\equiv\enc_{k}\left(m_{1}\right)$
\end_inset

.
\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Definition
\begin_inset Argument 1
status open

\begin_layout Plain Layout
Indistinguishability Game
\end_layout

\end_inset

 For an 
\emph on
adversary 
\emph default

\begin_inset Formula $\mathcal{A}:\CC\xrightarrow{}\binary$
\end_inset

 we define the following game:
\end_layout

\begin_deeper
\begin_layout Itemize
\begin_inset Formula $\mathcal{A}$
\end_inset

 chooses messages 
\begin_inset Formula $m_{0},m_{1}\in\MM$
\end_inset

.
\end_layout

\begin_layout Itemize
We sample a key 
\begin_inset Formula $k\r\KK$
\end_inset

 and a bit 
\begin_inset Formula $b\xleftarrow{}\binary$
\end_inset

.
\end_layout

\begin_layout Itemize
We send 
\begin_inset Formula $\enc_{k}\left(m_{b}\right)$
\end_inset

 to 
\begin_inset Formula $\mathcal{A}$
\end_inset

,
 called the 
\emph on
challenge
\emph default
.
\end_layout

\begin_layout Itemize
\begin_inset Formula $\mathcal{A}$
\end_inset

 outputs a bit 
\begin_inset Formula $b'$
\end_inset

.
\end_layout

\end_deeper
\begin_layout Definition
We say that 
\begin_inset Formula $\mathcal{A}$
\end_inset

 
\series bold
wins
\series default
 if 
\begin_inset Formula $b'=b$
\end_inset

,
 and we denote 
\begin_inset Formula $\Pr\left[\mathcal{A}\text{ wins}\right]\triangleq\Pr\left[b=b'\right]$
\end_inset

.
\end_layout

\begin_layout Theorem
Let 
\begin_inset Formula $\left(\enc,\dec\right)$
\end_inset

 be a symmetric encryption scheme.
 Then,
 the following are equivalent:
\end_layout

\begin_deeper
\begin_layout Enumerate
\begin_inset Formula $\left(\enc,\dec\right)$
\end_inset

 is 
\emph on
perfectly secret
\emph default
.
\begin_inset CommandInset label
LatexCommand label
name "enu:th1ps"

\end_inset


\end_layout

\begin_layout Enumerate
\begin_inset Formula $\left(\enc,\dec\right)$
\end_inset

 is 
\emph on
perfectly indistinguishable
\emph default
.
\begin_inset CommandInset label
LatexCommand label
name "enu:th1pi"

\end_inset


\end_layout

\begin_layout Enumerate
For any adversary 
\begin_inset Formula $\mathcal{A}$
\end_inset

,
 
\begin_inset Formula $\Pr\left[\mathcal{A}\text{ wins}\right]=\frac{1}{2}$
\end_inset

.
\begin_inset CommandInset label
LatexCommand label
name "enu:th1ig"

\end_inset


\end_layout

\begin_layout Proof
\begin_inset Formula $\eqref{enu:th1ps}\iff\eqref{enu:th1pi}$
\end_inset

 was left to HW1,
 Q1.
 
\begin_inset Formula $\underline{\eqref{enu:th1pi}\Longrightarrow\eqref{enu:th1ig}:}$
\end_inset

 Let 
\begin_inset Formula $\mathcal{A}$
\end_inset

 be an adversary,
 w.l.o.g deterministic,
 and let 
\begin_inset Formula $m_{0},m_{1}\in\MM$
\end_inset

.
 Define 
\begin_inset Formula $S_{b}\triangleq\mathcal{A}^{-1}\left(\left\{ b\right\} \right)$
\end_inset

 for 
\begin_inset Formula $b\in\binary$
\end_inset

,
 then 
\begin_inset Formula $S_{0}\uplus S_{1}=\CC$
\end_inset

.
 Let 
\begin_inset Formula $b'=\mathcal{A}\left(m_{b}\right)$
\end_inset

,
 where 
\begin_inset Formula $b\xleftarrow{}\binary$
\end_inset

,
 since 
\begin_inset Formula $\left(\enc,\dec\right)$
\end_inset

 is p.i.,
 then by total probability
\begin_inset Formula 
\begin{align*}
\Pr\left[\mathcal{A}\text{ wins}\right] & =\Pr\left[b'=b|b=0\right]\Pr\left[b=0\right]+\Pr\left[b'=b|b=1\right]\Pr\left[b=1\right]\\
 & =\frac{1}{2}\left(\Pr\left[\enc_{k}\left(m_{0}\right)\in S_{0}\right]+\Pr\left[\enc_{k}\left(m_{1}\right)\in S_{1}\right]\right)\\
 & =\frac{1}{2}\left(\Pr\left[\enc_{k}\left(m_{0}\right)\in S_{0}\right]+\Pr\left[\enc_{k}\left(m_{0}\right)\in S_{1}\right]\right)\\
 & =\frac{1}{2}\Pr\left[\enc_{k}\left(m_{0}\right)\in S_{0}\uplus S_{1}\right]=\frac{1}{2}.
\end{align*}

\end_inset

 
\begin_inset Formula $\underline{\eqref{enu:th1ig}\Longrightarrow\eqref{enu:th1pi}:}$
\end_inset

 Suppose 
\begin_inset Formula $\left(\enc,\dec\right)$
\end_inset

 is not p.i.,
 then there must be some 
\begin_inset Formula $m_{0},m_{1}\in\MM,c^{*}\in\CC$
\end_inset

 s.t.
\begin_inset Formula 
\[
\alpha=\Pr\left[\enc_{k}\left(m_{0}\right)=c^{*}\right]>\Pr\left[\enc_{k}\left(m_{1}\right)=c^{*}\right]=\beta.
\]

\end_inset

Consider the adversary 
\begin_inset Formula $\mathcal{A}$
\end_inset

 that selects the messages 
\begin_inset Formula $m_{0},m_{1}$
\end_inset

,
 and on input 
\begin_inset Formula $c\in\CC$
\end_inset

,
 
\begin_inset Formula $\mathcal{A}\left(c\right)=\mathds{1}\left[c\neq c^{*}\right]$
\end_inset

.
 Then by total probability
\begin_inset Formula 
\begin{align*}
\Pr\left[\mathcal{A}\text{ wins}\right] & =\Pr\left[b'=b|b=0\right]\Pr\left[b=0\right]+\Pr\left[b'=b|b=1\right]\Pr\left[b=1\right]\\
 & =\frac{1}{2}\left(\Pr\left[\enc_{k}\left(m_{0}\right)=c^{*}\right]+\Pr\left[\enc_{k}\left(m_{1}\right)\neq c^{*}\right]\right)\\
 & =\frac{1}{2}\left(\alpha+\left(1-\beta\right)\right)=\frac{1}{2}+\frac{1}{2}\left(\alpha-\beta\right)>\frac{1}{2}.
\end{align*}

\end_inset


\end_layout

\end_deeper
\begin_layout Section
One-Time Pad
\end_layout

\begin_layout Definition
\begin_inset Argument 1
status open

\begin_layout Plain Layout
One-Time Pad
\end_layout

\end_inset

 Let 
\begin_inset Formula $\MM=\KK=\CC=\str n$
\end_inset

,
 then for any 
\begin_inset Formula $m,k,c\in\str n$
\end_inset

 (where 
\begin_inset Formula $\oplus$
\end_inset

 is bitwise XOR),
 we define the 
\series bold
one-time pad 
\series default
scheme:
\begin_inset Formula 
\begin{align*}
\enc_{k}\left(m\right)=m\oplus k & , & \dec_{k}\left(c\right)=c\oplus k & .
\end{align*}

\end_inset


\end_layout

\begin_layout Theorem
One-Time Pad is 
\emph on
perfectly secret
\emph default
.
\end_layout

\begin_deeper
\begin_layout Proof
It is suffice to show the following claim:
\end_layout

\begin_deeper
\begin_layout Claim
For any 
\begin_inset Formula $m,c\in\str n$
\end_inset


\begin_inset Formula 
\[
\Pr_{k\r\str n}\left[\enc_{k}\left(m\right)=c\right]=\frac{1}{2^{n}}\iff\enc_{k}\left(m\right)\sim\mathcal{U}_{n}
\]

\end_inset


\end_layout

\begin_layout Standard
The claim implies the theorem from transitivity,
 for any 
\begin_inset Formula $m_{0},m_{1}\in\str n$
\end_inset

,
 where 
\begin_inset Formula $k\r\str n$
\end_inset

:
\begin_inset Formula 
\[
\enc_{k}\left(m_{0}\right)\equiv\mathcal{U}_{n}\equiv\enc_{k}\left(m_{1}\right)
\]

\end_inset


\end_layout

\begin_layout Standard

\series bold
Proof of the claim.

\series default
 Let 
\begin_inset Formula $m,c\in\str n$
\end_inset

,
 then:
\begin_inset Formula 
\[
\Pr_{k}\left[\enc_{k}\left(m\right)=c\right]=\Pr_{k}\left[m\oplus k=c\right]=\Pr_{k}\left[k=m\oplus c\right]=\frac{1}{2^{n}}
\]

\end_inset

 since 
\begin_inset Formula $m\oplus c$
\end_inset

 is a constant and 
\begin_inset Formula $k\sim\mathcal{U}_{n}$
\end_inset

.
\end_layout

\end_deeper
\end_deeper
\begin_layout Section
Shannon's Theorem
\end_layout

\begin_layout Theorem
\begin_inset Argument 1
status open

\begin_layout Plain Layout
Shannon
\end_layout

\end_inset

 If 
\begin_inset Formula $\left(\enc,\dec\right)$
\end_inset

 is perfectly secret,
 then 
\begin_inset Formula $\left|\KK\right|\geq\left|\MM\right|$
\end_inset

.
\end_layout

\begin_deeper
\begin_layout Proof
Define a two-sided graph 
\begin_inset Formula $G=\left(V,E\right)$
\end_inset

 where 
\begin_inset Formula $V=\MM\uplus\CC$
\end_inset

,
 
\begin_inset Formula $\left\{ m,c\right\} \in E$
\end_inset

 if and only if there exists 
\begin_inset Formula $k\in\KK$
\end_inset

 s.t.
 
\begin_inset Formula $\enc_{k}\left(m\right)=c$
\end_inset

.
 Assume for sake of contradiction that 
\begin_inset Formula $\left|\KK\right|<\left|\MM\right|$
\end_inset

,
 and let 
\begin_inset Formula $\left\{ m,c\right\} \in E$
\end_inset

.
\end_layout

\begin_deeper
\begin_layout Claim
\begin_inset Formula $c$
\end_inset

 is connected to at most 
\begin_inset Formula $\left|\KK\right|$
\end_inset

 messages,
 i.e.
 
\begin_inset Formula $\deg\left(c\right)\leq\left|\KK\right|$
\end_inset

.
\end_layout

\begin_layout Standard

\series bold
Proof of the claim.

\series default
 Assume for sake of contradiction that 
\begin_inset Formula $\deg\left(c\right)>\left|\KK\right|$
\end_inset

.
 By the pidgeonhole principle,
 there exists a key 
\begin_inset Formula $k\in\KK$
\end_inset

 and two messages 
\begin_inset Formula $m_{0},m_{1}\in\MM$
\end_inset

 s.t.
 
\begin_inset Formula $c=\enc_{k}\left(m_{0}\right)=\enc_{k}\left(m_{1}\right)$
\end_inset

 and that is a contradiction to the correctness of 
\begin_inset Formula $\left(\enc,\dec\right)$
\end_inset

.
\end_layout

\begin_layout Corollary
There exists a message 
\begin_inset Formula $m^{*}\in\MM$
\end_inset

 that isn't a neighbor of 
\begin_inset Formula $c$
\end_inset

.
\end_layout

\end_deeper
\begin_layout Proof
For any key 
\begin_inset Formula $k\in\KK$
\end_inset

,
 it holds that 
\begin_inset Formula $\enc_{k}\left(m^{*}\right)\neq c$
\end_inset

,
 and thus 
\begin_inset Formula ${\displaystyle \Pr_{k}\left[\enc_{k}\left(m^{*}\right)=c\right]=0}$
\end_inset

.
\end_layout

\begin_layout Proof
Since 
\begin_inset Formula $\left\{ m,c\right\} \in E$
\end_inset

,
 there exists a key 
\begin_inset Formula $k'\in\KK$
\end_inset

 s.t.
 
\begin_inset Formula $\enc_{k'}\left(m\right)=c$
\end_inset

,
 and thus 
\begin_inset Formula ${\displaystyle \Pr_{k}\left[\enc_{k}\left(m\right)=c\right]\geq\frac{1}{\left|\KK\right|}}>0$
\end_inset

.
\end_layout

\begin_layout Proof
We then conclude 
\begin_inset Formula $\enc_{k}\left(m^{*}\right)\not\equiv\enc_{k}\left(m\right)$
\end_inset

,
 where 
\begin_inset Formula $k\xleftarrow{}\KK$
\end_inset

,
 which is a contradiction.
\end_layout

\end_deeper
\end_inset


\end_layout

\begin_layout Chapter
Computational Secrecy & Pseudorandomness
\end_layout

\begin_layout Standard
\begin_inset Branch computesecrecy
inverted 0
status open

\begin_layout Section
Computational Secrecy
\end_layout

\begin_layout Claim
