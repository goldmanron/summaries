\series default

\begin_inset Formula $\hat{\Lambda}:\mathcal{H}\rightarrow\mathcal{H}$
\end_inset

 הינו פונקציה 
\begin_inset Formula $\hat{\Lambda}:\mathbb{R}^{2}\rightarrow\mathbb{C},\left(x,x'\right)\rightarrow\hat{\Lambda}_{xx'}$
\end_inset

 כך שמתקיים:
\begin_inset Formula 
\[
\hat{\Lambda}_{xx'}\triangleq\left\langle x\right|\hat{\Lambda}\left|x'\right\rangle 
\]

\end_inset


\end_layout

