\end_inset

 מרחב מכפלה פנימית מרוכב 
\begin_inset Formula $\left(\mathcal{H},\braket{\cdot}{\cdot}\right)$
\end_inset

 ייקרא 
\series bold
מרחב הילברט פיזיקלי 
\series default
אם קיימת מערכת מצבים 
\begin_inset Formula $\left\{ \left|x\right\rangle \right\} _{x\in\mathbb{R}}\subseteq\mathcal{H}^{*}$
\end_inset

 המקיימת את התכונות הבאות:
\end_layout

\begin_deeper
\begin_layout Enumerate

\series bold
נרמול:

\series default
 
\begin_inset Formula $\braket x{x'}=\delta\left(x-x'\right)$
\end_inset


\end_layout

\begin_layout Enumerate

\series bold
שלמות:

\series default
 
\begin_inset Formula $\intop_{\mathbb{R}}\left|x\right\rangle \left\langle x\right|dx=I$
\end_inset

,
 כאשר 
\begin_inset Formula $I$
\end_inset

 הוא אופרטור הזהות על 
\begin_inset Formula $\mathcal{H}$
\end_inset

.
\end_layout

\end_deeper
\begin_layout Definition
לכל 
\begin_inset Formula $\left|\psi\right\rangle \in\mathcal{H}$
\end_inset

 נגדיר את 
\series bold
פונקציית הגל שלו
\series default
 
\begin_inset Formula $\psi:\mathbb{R}\rightarrow\mathbb{C}$
\end_inset

 על ידי הטלה של המצב 
\begin_inset Formula $\left|\psi\right\rangle $
\end_inset

 על הבסיס הרציף:
\begin_inset Formula 
\[
\psi\left(x\right)\triangleq\braket x{\psi}
\]

\end_inset


\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Claim
לכל וקטור 
\begin_inset Formula $\left|\psi\right\rangle $
\end_inset

 מתקיים
\begin_inset Formula 
\[
\left|\psi\right\rangle =\intop_{\mathbb{R}}\psi\left(x\right)\left|x\right\rangle dx
\]

\end_inset


\end_layout

